# Normalize line endings to LF in the repo, checkout as-is on Windows
* text=auto eol=lf

# Force binary files to never be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# Minified JS/CSS — treat as binary to suppress diffs
*.min.js binary
*.min.css binary
