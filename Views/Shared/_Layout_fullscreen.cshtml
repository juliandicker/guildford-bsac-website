@{
    Layout = "~/Views/Shared/_Layout_empty.cshtml";
}
@section styles {
    <link href="~/Content/owl.carousel.css" rel="stylesheet" />
    <link href="~/Content/animate.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.6.1/css/font-awesome.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    @RenderSection("styles", false)
}

<partial name="_header" />
@RenderBody()
<partial name="_footer" />

@section scripts {
    <script src="~/Scripts/owl.carousel.min.js"></script>
    <script src="~/Scripts/jquery.waypoints.min.js"></script>
    <script>
        var offset = 96;

function NavBarScroll() {
            var scroll = $(window).scrollTop();
            var screenWidth = $(window).width();

            if (scroll >= 100 || screenWidth < 768) {
                $(".navbar-dark").addClass("bg-dark");
                $("#logo").removeClass("largelogo");
            } else {
                $(".navbar-dark").removeClass("bg-dark");
                $("#logo").addClass("largelogo");
            }
        }

        NavBarScroll();

        $(window).scroll(function () {
            NavBarScroll();
        });

        $('[data-animate]').waypoint(function (direction) {
            if (direction === 'down' && !$(this).hasClass('animated')) {
                var $el = $(this.element);
                setTimeout(function () {
                    $el.addClass('animated ' + $el.data("animate"));
                }, 200);
            }
        }, { offset: '80%' });

    </script>
    @RenderSection("scripts", false)
}
