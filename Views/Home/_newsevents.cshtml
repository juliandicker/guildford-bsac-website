<section id="newsevents" class="content-block bg-clouds">
    <div class="container">
        <div class="underlined-title">
            <h1>News & Events</h1>
            <hr />
        </div>
        <div class="row">
            <div class="col-6">
                <p class="fb-feed-label">Our Diving Year</p>
                <p class="small text-muted">A snapshot of the dive trips, training and social events we run throughout the year. Click to open the full planner.</p>
                <a href="@Url.Action("Index", "YearPlanner")" target="_blank">
                    <img src="/YearPlanner/png?agenda=False" class="img-fluid" />
                </a>
            </div>
            <div class="col-6">
                <p class="fb-feed-label">Latest from Facebook</p>
                <div class="fb-feed-scroll">
                    @if (Model.RecentPosts != null && Model.RecentPosts.Count > 0)
                    {
                        foreach (var post in Model.RecentPosts)
                        {
                            <div class="fb-post-card">
                                @if (!string.IsNullOrEmpty(post.FullPicture))
                                {
                                    <div class="fb-post-thumb">
                                        <img src="@post.FullPicture" alt="" />
                                    </div>
                                }
                                <div class="fb-post-content">
                                    <p>@(post.Message ?? post.Story)</p>
                                    <div class="fb-post-footer">
                                        <small>@post.CreatedTime.ToString("d MMM yyyy")</small>
                                        <a href="@post.PermalinkUrl" target="_blank" rel="noopener">View &rarr;</a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="fb-post-card fb-post-placeholder">
                            <p>Follow us on Facebook for the latest club news and updates.</p>
                            <a href="https://www.facebook.com/GuildfordBSAC/" target="_blank" rel="noopener noreferrer">
                                Visit our Facebook Page
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
