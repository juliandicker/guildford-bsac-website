@model GuildfordBsac.Web.Models.ContactViewModel

@using (Html.BeginForm("Contact", "Home", null, FormMethod.Post, null, new { id = "ContactForm" }))
{
    @Html.AntiForgeryToken()
<div id="form">
    <div id="errorContainer" class="alert alert-danger" style="display: none">
        Validation issues:
        <div id="errors"></div>
    </div>
    @Html.EditorFor(model => model.Name)
    @Html.EditorFor(model => model.Emaily)
    @Html.EditorFor(model => model.Emailx, new { htmlAttributes = new { @class = "gold", autocomplete = "email-off" } })
    @Html.EditorFor(model => model.Subject)
    @Html.EditorFor(model => model.Message, new { htmlAttributes = new { rows = "4" } })

    <div class="mb-3">
        <div class="g-recaptcha float-start" data-sitekey="6LfEV_wsAAAAAMQzxEIKxFMDMKkxAiNXU7IRo-b-"></div>
        <button type="submit" id="submit" class="btn btn-primary float-end">Submit</button>
    </div>
</div>
    <div id="sent">
        <h4>Thank you</h4>
        <p>Your email has been sent and we will get back to you shortly.</p>
    </div>
}